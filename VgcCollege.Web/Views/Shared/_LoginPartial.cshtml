@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <span class="nav-link text-dark">Hello @User.Identity?.Name!</span>
        </li>

        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Admin" asp-action="MyProfile">My Profile</a>
            </li>
        }
        @if (User.IsInRole("Faculty"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="FacultyProfile" asp-action="MyProfile">My Profile</a>
            </li>
        }
        @if (User.IsInRole("Student"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="StudentProfile" asp-action="MyProfile">My Profile</a>
            </li>
        }

        <li class="nav-item">
            <form method="post" asp-area="Identity" asp-page="/Account/Logout">
                <button type="submit" class="btn btn-link">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>