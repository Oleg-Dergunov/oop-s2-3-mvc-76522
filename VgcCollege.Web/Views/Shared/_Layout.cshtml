<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VgcCollege.Web</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

</head>
<body>
    <div class="page-container">

        <header>
            <nav class="topbar">
                <div class="d-flex align-items-center gap-3">
                    <a asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo.png" class="nav-logo" alt="Logo" />
                    </a>

                    <div class="menu-links d-flex gap-3">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Branch" asp-action="Index">Branches</a>
                            <span>|</span>
                            <a asp-controller="Course" asp-action="Index">Courses</a>
                            <span>|</span>
                            <a asp-controller="StudentProfile" asp-action="Index">Students</a>
                            <span>|</span>
                            <a asp-controller="FacultyProfile" asp-action="Index">Faculty</a>
                            <span>|</span>
                            <a asp-controller="Admin" asp-action="Index">Admins</a>
                        }
                        @if (User.IsInRole("Faculty"))
                        {
                            <a asp-controller="Course" asp-action="Index">Courses</a>
                        }
                        @if (User.IsInRole("Student"))
                        {
                            <a asp-controller="Course" asp-action="Index">Courses</a>
                            <span>|</span>
                            <a asp-controller="Assignment" asp-action="MyResults">Assignments</a>
                            <span>|</span>
                            <a asp-controller="Exam" asp-action="MyResults">Exams</a>
                        }
                    </div>
                </div>

                <div class="login-block d-flex align-items-center gap-2">
                    <partial name="_LoginPartial" />
                </div>
            </nav>
        </header>

        <br />
        <main role="main">
            @RenderBody()
        </main>

        <footer class="border-top footer text-muted mt-4 py-3">
            <br />
            <div class="container">
                &copy; 2026 - VgcCollege.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>