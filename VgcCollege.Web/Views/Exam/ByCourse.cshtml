@model IEnumerable<VgcCollege.Domain.Models.Exam>

@{
    ViewData["Title"] = "Exams";
    var studentProfileId = ViewBag.StudentProfileId as int?;
}

<h1>Exams</h1>
<h4>@ViewBag.CourseName</h4>
<hr />

@if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
{
    <p>
        <a asp-action="Create" asp-route-courseId="@ViewBag.CourseId">Create New</a>
    </p>
}

<table>
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Title)</th>
            <th>@Html.DisplayNameFor(m => m.Date)</th>
            <th>@Html.DisplayNameFor(m => m.MaxScore)</th>
            @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
            {
                <th>@Html.DisplayNameFor(m => m.ResultsReleased)</th>
            }
            @if (User.IsInRole("Student"))
            {
                <th>My Score</th>
                <th>My Grade</th>
            }
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var myResult = studentProfileId.HasValue
            ? item.Results.FirstOrDefault(r => r.StudentProfileId == studentProfileId)
            : null;
            <tr>
                <td>@Html.DisplayFor(m => item.Title)</td>
                <td>@Html.DisplayFor(m => item.Date)</td>
                <td>@Html.DisplayFor(m => item.MaxScore)</td>
                @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
                {
                    <td>@(item.ResultsReleased ? "Yes" : "No")</td>
                    <td>
                        <a asp-action="Results" asp-route-examId="@item.Id">Results</a>
                        <span> | </span>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    </td>
                }
                @if (User.IsInRole("Student"))
                {
                    if (item.ResultsReleased && myResult != null)
                    {
                        <td>@myResult.Score</td>
                        <td>@myResult.Grade</td>
                    }
                    else if (!item.ResultsReleased)
                    {
                        <td colspan="2"><em>Results not yet released</em></td>
                    }
                    else
                    {
                        <td>-</td>
                        <td>-</td>
                    }
                    <td></td>
                }
            </tr>
        }
    </tbody>
</table>

<br />

<div>
    <a asp-controller="Course" asp-action="Details" asp-route-id="@ViewBag.CourseId">Back to Course</a>
</div>